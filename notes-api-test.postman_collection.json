		{
			"name": "Delete Note",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('response status code should have 200 value', () => {\r",
							"   pm.expect(pm.response.code).to.eql(200);\r",
							"});\r",
							"\r",
							"pm.test('response Content-Type header should have application/json value', () => {\r",
							"   pm.expect(pm.response.headers.get('Content-Type'))\r",
							"     .to.include('application/json');\r",
							"}); \r",
							"\r",
							"pm.test('response body should be an object', () => {\r",
							"   const responseJson = pm.response.json();\r",
							"   pm.expect(responseJson).to.be.an('object');\r",
							"});\r",
							"\r",
							"pm.test('response body should have correct property and value', () => {\r",
							"   const responseJson = pm.response.json();\r",
							"\r",
							"   console.log('DELETE RESPONSE:', responseJson);\r",
							"\r",
							"   pm.expect(responseJson).to.have.property('status');\r",
							"   pm.expect(responseJson.status).to.eql('success');\r",
							"\r",
							"   pm.expect(responseJson).to.have.property('message');\r",
							"   pm.expect(responseJson.message).to.include('dihapus'); // 🔥 lebih fleksibel\r",
							"}); \r",
							"\r",
							"pm.test('response body should NOT have data property', () => {\r",
							"   const responseJson = pm.response.json();\r",
							"   pm.expect(responseJson).to.not.have.property('data');\r",
							"});\r",
							"\r",
							"pm.test('when request the deleted note', () => {\r",
							"    const noteId = pm.environment.get('noteId');\r",
							"\r",
							"    pm.expect(noteId).to.not.be.undefined;\r",
							"\r",
							"    pm.sendRequest(`http://localhost:3000/notes/${noteId}`, (error, response) => {\r",
							"\r",
							"        pm.test('the deleted note should be not found', () => {\r",
							"            pm.expect(error).to.be.null;\r",
							"            pm.expect(response.code).to.eql(404);\r",
							"\r",
							"            const responseJson = response.json();\r",
							"            console.log('AFTER DELETE:', responseJson);\r",
							"\r",
							"            pm.expect(responseJson.status).to.eql('fail'); \r",
							"            pm.expect(responseJson.message).to.include('tidak ditemukan');\r",
							"        });\r",
							"    });\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
